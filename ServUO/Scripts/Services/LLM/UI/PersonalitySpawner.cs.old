        private static Item CreateItem(string itemName)
        {
            try
            {
                switch (itemName)
                {
                    // Armor
                    case "PlateChest": return new PlateChest();
                    case "PlateLegs": return new PlateLegs();
                    case "PlateArms": return new PlateArms();
                    case "PlateGloves": return new PlateGloves();
                    case "ChainLegs": return new ChainLegs();
                    case "StuddedChest": return new StuddedChest();
                    case "StuddedLegs": return new StuddedLegs();
                    case "LeatherChest": return new LeatherChest();
                    case "LeatherLegs": return new LeatherLegs();
                    case "LeatherGloves": return new LeatherGloves();

                    // Helmets
                    case "CloseHelm": return new CloseHelm();
                    case "LeatherCap": return new LeatherCap();

                    // Clothing
                    case "Robe": return new Robe(Utility.RandomNeutralHue());
                    case "MonkRobe": return new MonkRobe();
                    case "FancyShirt": return new FancyShirt();
                    case "Shirt": return new Shirt();
                    case "Doublet": return new Doublet();
                    case "LongPants": return new LongPants();
                    case "ShortPants": return new ShortPants();
                    case "FancyDress": return new FancyDress();
                    case "GildedDress": return new GildedDress();
                    case "Cloak": return new Cloak();

                    // Footwear
                    case "Boots": return new Boots();
                    case "Sandals": return new Sandals();

                    // Hats
                    case "WizardsHat": return new WizardsHat(Utility.RandomBlueHue());
                    case "FeatheredHat": return new FeatheredHat();
                    case "FloppyHat": return new FloppyHat();
                    case "SkullCap": return new SkullCap();
                    case "TricorneHat": return new TricorneHat();
                    case "Bandana": return new Bandana();
                    case "Circlet": return new Circlet();

                    // Accessories
                    case "FullApron": return new FullApron();
                    case "HalfApron": return new HalfApron();

                    default:
                        Console.WriteLine($"[PersonalitySpawner] Unknown item: {itemName}");
                        return null;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[PersonalitySpawner] Error creating item {itemName}: {ex.Message}");
                return null;
            }
        }
    }
}
