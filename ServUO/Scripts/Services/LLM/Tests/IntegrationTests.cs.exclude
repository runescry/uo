using System;
using System.Collections.Generic;
using System.Threading.Tasks;
using Server;
using Server.Commands;
using Server.Mobiles;
using Server.Services.LLM;

namespace Server.Services.LLM.Tests
{
    /// <summary>
    /// Integration tests for LLM conversation plugin, knowledge base, and memory system
    /// </summary>
    public class IntegrationTests
    {
        public static void Initialize()
        {
            CommandSystem.Register("TestLLMIntegration", AccessLevel.Administrator, TestLLMIntegration_OnCommand);
        }

        [Usage("TestLLMIntegration")]
        [Description("Run comprehensive integration tests for LLM conversation plugin, knowledge base, and memory system")]
        private static void TestLLMIntegration_OnCommand(CommandEventArgs e)
        {
            Mobile from = e.Mobile;

            from.SendMessage("=== LLM Integration Test Suite ===");
            from.SendMessage("Running tests... Check console for detailed output.");
            from.SendMessage("");

            // Run tests asynchronously
            _ = Task.Run(async () =>
            {
                await RunIntegrationTests(from);
            });

            from.SendMessage("Tests started! Check server console for results.");
        }

        private static async Task RunIntegrationTests(Mobile from)
        {
            int testsPassed = 0;
            int testsFailed = 0;

            Console.WriteLine("╔════════════════════════════════════════════════════════════╗");
            Console.WriteLine("║          LLM Integration Test Suite                        ║");
            Console.WriteLine("╚════════════════════════════════════════════════════════════╝");
            Console.WriteLine();

            // Test 1: Plugin Enable/Disable
            Console.WriteLine("[TEST 1] Plugin Enable/Disable");
            try
            {
                bool initialState = LLMConversationPlugin.Enabled;
                LLMConversationPlugin.Enabled = !initialState;
                bool newState = LLMConversationPlugin.Enabled;
                LLMConversationPlugin.Enabled = initialState; // Restore

                if (newState != initialState)
                {
                    Console.WriteLine("  ✓ Plugin toggle works");
                    testsPassed++;
                }
                else
                {
                    Console.WriteLine("  ✗ Plugin toggle failed");
                    testsFailed++;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"  ✗ Plugin toggle error: {ex.Message}");
                testsFailed++;
            }
            Console.WriteLine();

            // Test 2: Knowledge Base Loading
            Console.WriteLine("[TEST 2] Knowledge Base Loading");
            try
            {
                var allLore = SimpleLoreSystem.GetAllLore();
                if (allLore.Count > 0)
                {
                    Console.WriteLine($"  ✓ Lore system has {allLore.Count} entries");
                    testsPassed++;
                }
                else
                {
                    Console.WriteLine("  ✗ Lore system is empty");
                    testsFailed++;
                }

                // Test role inference
                var blacksmithRole = NPCKnowledgeSystem.InferRoleFromPersonality(NPCPersonalities.PersonalityType.Blacksmith);
                if (blacksmithRole == NPCKnowledgeSystem.NPCRole.Blacksmith)
                {
                    Console.WriteLine("  ✓ Blacksmith personality maps to Blacksmith role");
                    testsPassed++;
                }
                else
                {
                    Console.WriteLine($"  ✗ Blacksmith personality maps to {blacksmithRole} (expected Blacksmith)");
                    testsFailed++;
                }

                // Test knowledge loading
                var roleKnowledge = NPCKnowledgeSystem.GetRoleKnowledge(blacksmithRole, allLore);
                if (roleKnowledge.Count > 0)
                {
                    Console.WriteLine($"  ✓ Blacksmith role knowledge loaded: {roleKnowledge.Count} entries");
                    testsPassed++;
                }
                else
                {
                    Console.WriteLine("  ✗ Blacksmith role knowledge is empty");
                    testsFailed++;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"  ✗ Knowledge base test error: {ex.Message}");
                testsFailed++;
            }
            Console.WriteLine();

            // Test 3: Memory Extraction
            Console.WriteLine("[TEST 3] Memory Extraction");
            try
            {
                var testMessages = new List<ConversationMessage>
                {
                    new ConversationMessage(true, "Hello"),
                    new ConversationMessage(true, "You are my best friend"),
                    new ConversationMessage(true, "My name is TestPlayer"),
                    new ConversationMessage(true, "I like dragons")
                };

                var memories = MemoryHelpers.ExtractMemoriesFromConversation("TestNPC", "TestPlayer", testMessages);
                
                if (memories.Count > 0)
                {
                    Console.WriteLine($"  ✓ Extracted {memories.Count} memories");
                    testsPassed++;

                    // Check for best friend memory
                    var bestFriendMemory = memories.Find(m => m.Content.Contains("best friend"));
                    if (bestFriendMemory != null && bestFriendMemory.Importance == 10)
                    {
                        Console.WriteLine("  ✓ 'Best friend' memory detected with importance 10");
                        testsPassed++;
                    }
                    else
                    {
                        Console.WriteLine("  ✗ 'Best friend' memory not detected or wrong importance");
                        testsFailed++;
                    }
                }
                else
                {
                    Console.WriteLine("  ✗ No memories extracted");
                    testsFailed++;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"  ✗ Memory extraction test error: {ex.Message}");
                testsFailed++;
            }
            Console.WriteLine();

            // Test 4: Relationship Database
            Console.WriteLine("[TEST 4] Relationship Database");
            try
            {
                // Test relationship creation
                var testRelationship = new Relationship
                {
                    NpcName = "TestNPC",
                    PlayerName = "TestPlayer",
                    Type = RelationshipType.Friend,
                    Score = 50,
                    FirstMet = DateTime.UtcNow,
                    LastInteraction = DateTime.UtcNow,
                    InteractionCount = 1
                };

                // Try to save (will fail if database not available, but shouldn't throw)
                try
                {
                    await LLMMemoryService.UpdateRelationshipAsync("TestNPC", "TestPlayer", 10);
                    Console.WriteLine("  ✓ Relationship update method works (database may not be available)");
                    testsPassed++;
                }
                catch (Exception dbEx)
                {
                    if (dbEx.Message.Contains("score") || dbEx.Message.Contains("relationship_score"))
                    {
                        Console.WriteLine($"  ✗ Database schema error: {dbEx.Message}");
                        testsFailed++;
                    }
                    else
                    {
                        Console.WriteLine($"  ✓ Relationship update method works (database not available: {dbEx.Message})");
                        testsPassed++;
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"  ✗ Relationship test error: {ex.Message}");
                testsFailed++;
            }
            Console.WriteLine();

            // Test 5: ILLMConversational Interface
            Console.WriteLine("[TEST 5] ILLMConversational Interface");
            try
            {
                // Check if Mage implements the interface
                var mageType = typeof(Mage);
                if (typeof(ILLMConversational).IsAssignableFrom(mageType))
                {
                    Console.WriteLine("  ✓ Mage implements ILLMConversational");
                    testsPassed++;
                }
                else
                {
                    Console.WriteLine("  ✗ Mage does not implement ILLMConversational");
                    testsFailed++;
                }

                // Check if Actor implements the interface
                var actorType = typeof(Actor);
                if (typeof(ILLMConversational).IsAssignableFrom(actorType))
                {
                    Console.WriteLine("  ✓ Actor implements ILLMConversational");
                    testsPassed++;
                }
                else
                {
                    Console.WriteLine("  ✗ Actor does not implement ILLMConversational");
                    testsFailed++;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"  ✗ Interface test error: {ex.Message}");
                testsFailed++;
            }
            Console.WriteLine();

            // Summary
            Console.WriteLine("╔════════════════════════════════════════════════════════════╗");
            Console.WriteLine("║                      Test Summary                        ║");
            Console.WriteLine("╚════════════════════════════════════════════════════════════╝");
            Console.WriteLine($"Tests Passed: {testsPassed}");
            Console.WriteLine($"Tests Failed: {testsFailed}");
            Console.WriteLine($"Total Tests: {testsPassed + testsFailed}");
            Console.WriteLine();

            if (testsFailed == 0)
            {
                Console.WriteLine("✅ All integration tests passed!");
            }
            else
            {
                Console.WriteLine($"⚠️  {testsFailed} test(s) failed. Review output above.");
            }
            Console.WriteLine();

            // Send summary to player
            if (from != null && !from.Deleted)
            {
                from.SendMessage($"Integration tests complete: {testsPassed} passed, {testsFailed} failed");
                from.SendMessage("Check server console for detailed results.");
            }
        }
    }
}

