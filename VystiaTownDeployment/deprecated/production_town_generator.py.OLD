"""
Production UO Town Generator
Uses real OSI building templates to generate authentic towns
Writes directly to map/statics MUL files
"""

import json
import random
import math
import struct
from pathlib import Path
from typing import List, Dict, Tuple
from dataclasses import dataclass

@dataclass
class GenerationConfig:
    """Configuration for town generation"""
    name: str
    target_coordinates: Tuple[int, int]  # Center point (x, y)
    target_size: str  # 'small', 'medium', 'large'
    style: str  # 'dense', 'sparse', 'organic', 'grid'

    # Optional constraints
    building_density: float = 3.0  # buildings per 100 tiles
    min_building_spacing: int = 3  # Minimum tiles between buildings
    road_coverage: float = 0.15

class ProductionTownGenerator:
    """Generates production-ready towns using real OSI templates"""

    def __init__(self, template_library_file: str = 'template_library.json'):
        print(f"Loading template library from {template_library_file}...")
        with open(template_library_file, 'r') as f:
            self.library = json.load(f)

        print(f"Loaded templates:")
        for category, count in self.library['statistics'].items():
            print(f"  {category}: {count} templates")

    def generate_town(self, config: GenerationConfig) -> Dict:
        """Generate a complete town with real building templates"""
        print(f"\n=== Generating {config.name} ===")
        print(f"Style: {config.style}, Size: {config.target_size}")
        print(f"Center: ({config.target_coordinates[0]}, {config.target_coordinates[1]})")

        # Calculate town dimensions based on size
        dimensions = {
            'small': (100, 100),
            'medium': (200, 200),
            'large': (300, 300),
        }
        width, height = dimensions.get(config.target_size, (200, 200))

        # Calculate bounds
        cx, cy = config.target_coordinates
        bounds = {
            'x1': cx - width // 2,
            'y1': cy - height // 2,
            'x2': cx + width // 2,
            'y2': cy + height // 2,
        }

        print(f"Area: {width}x{height} tiles, Bounds: ({bounds['x1']},{bounds['y1']}) to ({bounds['x2']},{bounds['y2']})")

        # Initialize generation state
        state = {
            'config': config,
            'bounds': bounds,
            'width': width,
            'height': height,
            'placed_buildings': [],
            'all_statics': [],
            'occupied_grid': set(),
        }

        # Generation pipeline
        self._generate_road_network(state)
        self._place_buildings(state)

        return self._create_output(state)

    def _generate_road_network(self, state: Dict):
        """Generate road network"""
        config = state['config']
        bounds = state['bounds']

        if config.style == 'grid':
            self._generate_grid_roads(state, spacing=25)
        elif config.style == 'organic':
            self._generate_organic_roads(state)
        else:
            # Sparse/dense - just a few main roads
            self._generate_simple_roads(state)

        print(f"Generated {len([s for s in state['all_statics'] if s.get('is_road')])} road tiles")

    def _generate_grid_roads(self, state: Dict, spacing: int):
        """Generate grid-pattern roads"""
        bounds = state['bounds']
        road_tile_id = 0x0071  # Stone road

        # Horizontal roads
        for y in range(bounds['y1'] + spacing, bounds['y2'], spacing):
            for x in range(bounds['x1'], bounds['x2']):
                static = {
                    'tile_id': road_tile_id,
                    'x': x, 'y': y, 'z': 0, 'hue': 0,
                    'is_road': True
                }
                state['all_statics'].append(static)
                state['occupied_grid'].add((x, y))

        # Vertical roads
        for x in range(bounds['x1'] + spacing, bounds['x2'], spacing):
            for y in range(bounds['y1'], bounds['y2']):
                static = {
                    'tile_id': road_tile_id,
                    'x': x, 'y': y, 'z': 0, 'hue': 0,
                    'is_road': True
                }
                state['all_statics'].append(static)
                state['occupied_grid'].add((x, y))

    def _generate_organic_roads(self, state: Dict):
        """Generate organic winding roads"""
        bounds = state['bounds']
        center_x = (bounds['x1'] + bounds['x2']) // 2
        center_y = (bounds['y1'] + bounds['y2']) // 2

        road_tile_id = 0x009C  # Dirt path
        num_paths = random.randint(3, 5)

        for _ in range(num_paths):
            x, y = center_x, center_y
            steps = random.randint(40, 80)

            for _ in range(steps):
                # Random walk
                dx = random.randint(-1, 1)
                dy = random.randint(-1, 1)
                x += dx
                y += dy

                if bounds['x1'] <= x < bounds['x2'] and bounds['y1'] <= y < bounds['y2']:
                    static = {
                        'tile_id': road_tile_id,
                        'x': x, 'y': y, 'z': 0, 'hue': 0,
                        'is_road': True
                    }
                    state['all_statics'].append(static)
                    state['occupied_grid'].add((x, y))

    def _generate_simple_roads(self, state: Dict):
        """Generate a few main roads"""
        bounds = state['bounds']
        center_x = (bounds['x1'] + bounds['x2']) // 2
        center_y = (bounds['y1'] + bounds['y2']) // 2
        road_tile_id = 0x0071

        # Main horizontal road
        for x in range(bounds['x1'], bounds['x2']):
            static = {
                'tile_id': road_tile_id,
                'x': x, 'y': center_y, 'z': 0, 'hue': 0,
                'is_road': True
            }
            state['all_statics'].append(static)
            state['occupied_grid'].add((x, center_y))

        # Main vertical road
        for y in range(bounds['y1'], bounds['y2']):
            static = {
                'tile_id': road_tile_id,
                'x': center_x, 'y': y, 'z': 0, 'hue': 0,
                'is_road': True
            }
            state['all_statics'].append(static)
            state['occupied_grid'].add((center_x, y))

    def _place_buildings(self, state: Dict):
        """Place buildings using real templates"""
        config = state['config']
        bounds = state['bounds']
        area = state['width'] * state['height']

        # Calculate target number of buildings
        target_buildings = int((area / 10000) * config.building_density)

        # Select template category based on town size and style
        if config.style == 'dense':
            template_mix = {'small': 0.6, 'medium': 0.3, 'large': 0.1}
        elif config.style == 'sparse':
            template_mix = {'small': 0.3, 'medium': 0.4, 'large': 0.3}
        else:
            template_mix = {'small': 0.4, 'medium': 0.4, 'large': 0.2}

        placed = 0
        attempts = 0
        max_attempts = target_buildings * 10

        while placed < target_buildings and attempts < max_attempts:
            attempts += 1

            # Select category
            category = random.choices(
                list(template_mix.keys()),
                weights=list(template_mix.values())
            )[0]

            # Select random template from category
            if not self.library['templates'][category]:
                continue

            template = random.choice(self.library['templates'][category])

            # Try to place it
            if self._try_place_template(state, template):
                placed += 1
                if placed % 10 == 0:
                    print(f"  Placed {placed}/{target_buildings} buildings...")

        print(f"Placed {placed} buildings ({attempts} attempts)")

    def _try_place_template(self, state: Dict, template: Dict) -> bool:
        """Try to place a template at a random valid location"""
        bounds = state['bounds']
        width = template['width']
        height = template['height']
        min_spacing = state['config'].min_building_spacing

        # Random placement location
        max_attempts = 20
        for _ in range(max_attempts):
            px = random.randint(bounds['x1'] + 5, bounds['x2'] - width - 5)
            py = random.randint(bounds['y1'] + 5, bounds['y2'] - height - 5)

            # Check if area is clear
            clear = True
            for dy in range(-min_spacing, height + min_spacing):
                for dx in range(-min_spacing, width + min_spacing):
                    if (px + dx, py + dy) in state['occupied_grid']:
                        clear = False
                        break
                if not clear:
                    break

            if clear:
                # Place the template
                for static in template['statics']:
                    placed_static = static.copy()
                    placed_static['x'] = px + static['x']
                    placed_static['y'] = py + static['y']
                    state['all_statics'].append(placed_static)
                    state['occupied_grid'].add((placed_static['x'], placed_static['y']))

                state['placed_buildings'].append({
                    'x': px, 'y': py,
                    'width': width, 'height': height,
                    'source': template.get('source_town', 'unknown'),
                    'tile_count': len(template['statics'])
                })
                return True

        return False

    def _create_output(self, state: Dict) -> Dict:
        """Create output data structure"""
        return {
            'name': state['config'].name,
            'bounds': state['bounds'],
            'statics': state['all_statics'],
            'buildings': state['placed_buildings'],
            'statistics': {
                'total_statics': len(state['all_statics']),
                'total_buildings': len(state['placed_buildings']),
                'area': state['width'] * state['height'],
                'density': len(state['placed_buildings']) / ((state['width'] * state['height']) / 10000),
            }
        }

    def export_to_json(self, town_data: Dict, output_file: str):
        """Export to JSON for inspection"""
        with open(output_file, 'w') as f:
            json.dump(town_data, f, indent=2)
        print(f"\nExported to {output_file}")
        print(f"Statistics:")
        for key, value in town_data['statistics'].items():
            print(f"  {key}: {value}")


if __name__ == "__main__":
    generator = ProductionTownGenerator()

    # Generate Ironheart Capital
    config = GenerationConfig(
        name="Ironheart_Capital",
        target_coordinates=(450, 250),  # Vystia map coordinates
        target_size="large",
        style="grid",
        building_density=3.5,
        min_building_spacing=4,
    )

    town = generator.generate_town(config)
    generator.export_to_json(town, 'ironheart_capital_v2.json')
