# Vystia Project - Git Repository
# Only track: ServUO, Vystia, VystiaTerrainGeneration, VystiaTownDeployment

# Ignore everything by default
/*

# Explicitly include these four directories
!/ServUO/
/ServUO/*
!/ServUO/Scripts/
!/ServUO/Scripts/**
!/ServUO/Server/
!/ServUO/Server/**
!/ServUO/Config/
!/ServUO/Config/**
!/ServUO/*.sln
!/ServUO/*.csproj
!/ServUO/*.config
!/ServUO/*.md
!/Vystia/
!/VystiaTerrainGeneration/
!/VystiaTownDeployment/
!/.gitignore
!/README.md
!/AI_CORE_ARCHITECTURE.md
!/STUDY_GUIDE.md
!/study-app/

# But ignore build outputs and temporary files within included directories
**/bin/
**/obj/
**/Debug/
**/Release/
**/.vs/
**/*.user
**/*.suo
**/*.cache
**/*.dll
**/*.exe
**/*.pdb
**/*.log

# Ignore compiled Python files
**/__pycache__/
**/*.pyc
**/*.pyo

# Ignore OS files
**/Thumbs.db
**/.DS_Store
**/desktop.ini

# Ignore Windows reserved filenames
**/nul
**/NUL

# Ignore IDE files
**/.vscode/
**/.idea/
**/*.swp
**/*.swo

# Ignore temp and backup files
**/*~
**/*.bak
**/*.tmp
**/*.temp

# Ignore large binary map files (UO client files - too large for GitHub)
**/*.mul
**/*.uop
**/backups/
**/patched_client/
**/output/maps/

ServUO/Accounts/
ServUO/Data/
ServUO/Saves/
ServUO/Save.bad_*/
ServUO/Saves.bak_*/
ServUO/Saves_Backup_*/
ServUO/Logs/
ServUO/centredsharp/
